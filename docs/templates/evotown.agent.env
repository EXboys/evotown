# Evotown 员工端配置
# 复制到 ~/.config/evotown/evotown.agent.env
#
# 必填（MDM 下发）：
EVOTOWN_URL=https://evotown.company.internal
EVOTOWN_API_KEY=evk_replace_with_it_issued_key
#
# 派活（register --save-token 后写入，勿使用 IT bootstrap token）：
# EVOTOWN_ENGINE_ID=openclaw-alice
# EVOTOWN_TEAM_ID=sales
# EVOTOWN_ENGINE_INGEST_TOKEN=evi_xxxxxxxx
#
# Connector 可选：
# EVOTOWN_RUNTIME=openclaw
# EVOTOWN_DISPATCH_COMPLETION=poll_run
# OPENCLAW_HOOK_TOKEN=<与 openclaw hooks.token 相同>
