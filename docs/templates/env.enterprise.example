# ============================================================
# Evotown 企业私有化部署 — 最小配置模板
# 由 scripts/enterprise-deploy.sh 复制为 .env 并自动填充密钥
# ============================================================

# ── 对外访问地址（员工 OpenClaw/Hermes 配置里的 EVOTOWN_URL）────────
# 内网示例：https://evotown.company.internal
# 本地验证：http://127.0.0.1:8080
EVOTOWN_PUBLIC_URL=http://127.0.0.1:8080

# ── 上游大模型（LiteLLM 转发目标）────────────────────────────────
BASE_URL=https://api.openai.com/v1
API_KEY=your-upstream-llm-api-key
MODEL=gpt-4o-mini

# ── 服务鉴权（deploy 脚本自动生成，请勿提交到 git）────────────────
ADMIN_TOKEN=
EVOTOWN_ENGINE_INGEST_TOKEN=
LITELLM_MASTER_KEY=

# ── LiteLLM 内部路由 ─────────────────────────────────────────────
LITELLM_BASE_URL=http://litellm:4000/v1

# ── 生产加固（deploy 脚本强制写入；勿改为 1）──────────────────────
EVOTOWN_ALLOW_PUBLIC_REGISTER=0
EVOTOWN_DEV_ALLOW_ADMIN_AS_GATEWAY=0
EVOTOWN_DEV_ALLOW_ADMIN_TOKEN_FALLBACK=0

# ── 服务端口 ─────────────────────────────────────────────────────
PORT=8080
LITELLM_PORT=4000

# ── CORS（必须与 EVOTOWN_PUBLIC_URL 同源；* 会导致 --check 失败）──
CORS_ORIGINS=http://127.0.0.1:8080

# ── Coding Agent（Hosted Claude → Evotown Gateway Anthropic 端点）──
# 详见 docs/zh-CN/CODING_AGENT_AND_GATEWAY.md
# EVOTOWN_CLAUDE_USE_GATEWAY=1
# EVOTOWN_CLAUDE_GATEWAY_BASE_URL=http://backend:8765/api/gateway/anthropic
# EVOTOWN_CLAUDE_GATEWAY_API_KEY=<签发带 gateway.chat 的 evk_ key>
# EVOTOWN_CLAUDE_EXECUTION_MODE=sdk
